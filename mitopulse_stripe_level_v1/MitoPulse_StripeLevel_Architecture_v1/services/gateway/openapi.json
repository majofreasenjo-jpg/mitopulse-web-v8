{
  "openapi": "3.1.0",
  "info": {
    "title": "MitoPulse Verify API (Stripe-level Blueprint)",
    "version": "v4"
  },
  "paths": {
    "/v4/packets": {
      "post": {
        "summary": "Ingest signed proof packet",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Tenant-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Decision"
          },
          "409": {
            "description": "Duplicate/idempotent replay"
          }
        }
      }
    },
    "/v4/state": {
      "get": {
        "summary": "Get derived identity state",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "device_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "epoch",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "State"
          }
        }
      }
    }
  }
}