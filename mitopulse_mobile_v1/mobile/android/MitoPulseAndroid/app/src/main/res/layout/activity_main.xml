<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="16dp">
  <TextView android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:text="MitoPulse Mobile Prototype" android:textSize="20sp" android:textStyle="bold"/>
  <TextView android:id="@+id/status" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:text="Status: idle" android:paddingTop="12dp"/>
  <Button android:id="@+id/btnSendDemo" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:text="Send DEMO Event (Local-First)"/>
  <Button android:id="@+id/btnVerify" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:text="Verify (on-demand)" android:layout_marginTop="8dp"/>
</LinearLayout>
